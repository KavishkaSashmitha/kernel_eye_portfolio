---
const navItems = [
  { name: 'Home', href: '#home' },
  { name: 'Scope', href: '#scope' },
  { name: 'Milestones', href: '#milestones' },
  { name: 'Team', href: '#team' },
  { name: 'Achievements', href: '#achievements' },
  { name: 'Contact', href: '#contact' },
];

const downloadItems = [
  {
    label: 'Slides',
    href: '#presentations',
    icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3m0 0l3 3m-3-3v8m0-13a9 9 0 110 18 9 9 0 010-18z"/></svg>`,
    desc: 'Presentation decks',
  },
  {
    label: 'Documents',
    href: '#documents',
    icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
    desc: 'Research papers & reports',
  },
];
---

<header id="main-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-white/5" style="background: rgba(9,9,11,0.6); backdrop-filter: blur(20px);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="#home" class="flex items-center gap-2 group flex-shrink-0">
        <img src="/favicon.svg" alt="KernelEye" class="w-8 h-8 rounded-lg shadow-lg shadow-sky-500/30 group-hover:shadow-sky-500/50 transition-shadow" />
        <span class="text-lg font-bold font-heading bg-gradient-to-r from-sky-300 to-blue-400 bg-clip-text text-transparent tracking-tight">
          KernelEye
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="relative px-3 py-2 text-sm font-medium text-slate-400 hover:text-white rounded-md hover:bg-white/5 transition-all duration-200 group"
          >
            {item.name}
            <span class="absolute bottom-1 left-3 right-3 h-px bg-sky-400 scale-x-0 group-hover:scale-x-100 transition-transform duration-200 origin-left rounded-full"></span>
          </a>
        ))}

        <!-- Downloads Dropdown -->
        <div class="relative" id="downloads-dropdown-wrap">
          <button
            id="downloads-btn"
            class="relative flex items-center gap-1.5 px-3 py-2 text-sm font-medium text-slate-400 hover:text-white rounded-md hover:bg-white/5 transition-all duration-200 group"
            aria-haspopup="true"
            aria-expanded="false"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            Downloads
            <svg id="downloads-chevron" class="w-3.5 h-3.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
            <span class="absolute bottom-1 left-3 right-3 h-px bg-sky-400 scale-x-0 group-hover:scale-x-100 transition-transform duration-200 origin-left rounded-full"></span>
          </button>

          <!-- Dropdown Panel -->
          <div
            id="downloads-menu"
            class="downloads-menu absolute top-full right-0 mt-2 w-56 rounded-xl border border-white/10 shadow-2xl shadow-black/50 overflow-hidden opacity-0 scale-95 pointer-events-none transition-all duration-200 origin-top-right"
            style="background: rgba(15,15,20,0.95); backdrop-filter: blur(24px);"
          >
            <div class="p-1.5">
              {downloadItems.map((d) => (
                <a
                  href={d.href}
                  class="downloads-link flex items-start gap-3 px-3 py-2.5 rounded-lg hover:bg-white/8 transition-colors group/item"
                >
                  <span class="mt-0.5 text-sky-400 group-hover/item:text-sky-300 transition-colors flex-shrink-0" set:html={d.icon} />
                  <div>
                    <p class="text-sm font-medium text-slate-200 group-hover/item:text-white transition-colors">{d.label}</p>
                    <p class="text-xs text-slate-500 group-hover/item:text-slate-400 transition-colors">{d.desc}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </nav>

      <!-- Right Side -->
      <div class="flex items-center gap-2">
        <!-- Theme Toggle -->
        <button id="theme-toggle" class="p-2 rounded-lg text-slate-400 hover:text-white hover:bg-white/5 transition-all duration-200" aria-label="Toggle theme">
          <svg id="moon-icon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
          <svg id="sun-icon" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        </button>

        <!-- Mobile menu toggle -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-lg text-slate-400 hover:text-white hover:bg-white/5 transition-all duration-200" aria-label="Toggle menu">
          <svg id="hamburger-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-white/5" style="background: rgba(9,9,11,0.97); backdrop-filter: blur(24px);">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="mobile-link flex items-center px-4 py-3 text-sm font-medium text-slate-300 hover:text-white hover:bg-white/5 rounded-lg transition-all duration-200"
        >
          {item.name}
        </a>
      ))}

      <!-- Downloads section in mobile -->
      <div class="pt-2 border-t border-white/5 mt-2">
        <p class="px-4 py-1 text-xs font-semibold text-slate-600 uppercase tracking-wider">Downloads</p>
        {downloadItems.map((d) => (
          <a
            href={d.href}
            class="mobile-link flex items-center gap-3 px-4 py-3 text-sm font-medium text-slate-300 hover:text-white hover:bg-white/5 rounded-lg transition-all duration-200"
          >
            <span class="text-sky-400" set:html={d.icon} />
            <div>
              <p class="font-medium">{d.label}</p>
              <p class="text-xs text-slate-500">{d.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<script>
  // ---- Theme Toggle ----
  const html = document.documentElement;
  const moonIcon = document.getElementById('moon-icon');
  const sunIcon = document.getElementById('sun-icon');

  function applyTheme(theme: string) {
    if (theme === 'light') {
      html.setAttribute('data-theme', 'light');
      moonIcon?.classList.add('hidden');
      sunIcon?.classList.remove('hidden');
    } else {
      html.removeAttribute('data-theme');
      moonIcon?.classList.remove('hidden');
      sunIcon?.classList.add('hidden');
    }
  }

  function toggleTheme() {
    const isLight = html.getAttribute('data-theme') === 'light';
    const next = isLight ? 'dark' : 'light';
    localStorage.setItem('theme', next);
    applyTheme(next);
  }

  applyTheme(localStorage.getItem('theme') || 'dark');
  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);

  // ---- Downloads Dropdown ----
  const downloadsBtn = document.getElementById('downloads-btn');
  const downloadsMenu = document.getElementById('downloads-menu');
  const downloadsChevron = document.getElementById('downloads-chevron');
  let dropdownOpen = false;

  function openDropdown() {
    dropdownOpen = true;
    downloadsMenu?.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
    downloadsMenu?.classList.add('opacity-100', 'scale-100');
    downloadsChevron?.classList.add('rotate-180');
    downloadsBtn?.setAttribute('aria-expanded', 'true');
  }

  function closeDropdown() {
    dropdownOpen = false;
    downloadsMenu?.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
    downloadsMenu?.classList.remove('opacity-100', 'scale-100');
    downloadsChevron?.classList.remove('rotate-180');
    downloadsBtn?.setAttribute('aria-expanded', 'false');
  }

  downloadsBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    dropdownOpen ? closeDropdown() : openDropdown();
  });

  document.addEventListener('click', (e) => {
    if (!document.getElementById('downloads-dropdown-wrap')?.contains(e.target as Node)) {
      closeDropdown();
    }
  });

  document.querySelectorAll('.downloads-link').forEach(link => {
    link.addEventListener('click', closeDropdown);
  });

  // ---- Mobile Menu ----
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeMenuIcon = document.getElementById('close-icon');
  let isMenuOpen = false;

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;
    mobileMenu?.classList.toggle('hidden', !isMenuOpen);
    hamburgerIcon?.classList.toggle('hidden', isMenuOpen);
    closeMenuIcon?.classList.toggle('hidden', !isMenuOpen);
  }

  mobileMenuBtn?.addEventListener('click', toggleMenu);

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => { if (isMenuOpen) toggleMenu(); });
  });

  // ---- Scroll effect ----
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      header?.classList.add('border-white/10', 'shadow-lg');
      header?.classList.remove('border-white/5');
    } else {
      header?.classList.remove('border-white/10', 'shadow-lg');
      header?.classList.add('border-white/5');
    }
  });
</script>
