---
const scopeTabs = [
  {
    id: "literature",
    title: "Literature Survey",
    subtitle: "What the literature shows",
    body: "Existing Kubernetes systems use service meshes and monitoring tools to manage microservices, but they rely heavily on sidecar proxies and high-level metrics like CPU and memory. While tools like eBPF enable low-level observability, their integration into orchestration for real-time decision-making is still limited.",
  },
  {
    id: "gap",
    title: "Research Gap",
    subtitle: "What is missing today",
    body: "Current solutions introduce performance overhead through sidecars and lack the use of kernel-level telemetry for intelligent orchestration. There is no lightweight approach that combines real-time telemetry with routing, scaling, and scheduling decisions.",
  },
  {
    id: "problem",
    title: "Research Problem",
    subtitle: "The core challenge",
    body: "Traditional Kubernetes architectures reduce efficiency due to sidecar overhead and limited observability. The challenge is to design a system that improves performance using real-time telemetry while minimizing resource usage and complexity.",
  },
  {
    id: "objectives",
    title: "Research Objectives",
    subtitle: "What the project aims to achieve",
    body: "The project aims to develop a sidecar-less orchestration system that uses eBPF telemetry to enable intelligent traffic routing, autoscaling, and scheduling while improving system performance and scalability.",
  },
  {
    id: "methodology",
    title: "Methodology",
    subtitle: "How the system works",
    body: "The system collects kernel-level telemetry using eBPF, processes it through a unified interface, and uses it to make real-time decisions for routing, scaling, and scheduling. A distributed coordination layer ensures cluster-wide communication and optimization.",
  },
];
---

<section id="scope" class="py-16 relative">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-8 reveal"
    >
      <div>
        <h2
          class="text-3xl md:text-4xl font-bold font-heading tracking-tight text-white"
        >
          Research Domain
        </h2>
        <p class="text-slate-400 mt-4 max-w-2xl">
          The domain section captures the literature survey, research gap,
          research problem, research objectives, methodology, and the technology
          base used for KernelEye.
        </p>
      </div>
    </div>

    <div class="space-y-6">
      <div
        class="flex flex-wrap gap-3 justify-center lg:justify-start reveal"
        data-scope-tabs
      >
        {
          scopeTabs.map((tab, index) => (
            <button
              class={`focus-ring rounded-full px-4 py-2 text-sm font-medium border transition whitespace-nowrap ${
                index === 0
                  ? "bg-white/10 text-white border-white/20"
                  : "bg-white/5 text-slate-300 border-white/10 hover:border-white/20 hover:bg-white/10"
              }`}
              data-tab={tab.id}
              aria-selected={index === 0 ? "true" : "false"}
              type="button"
            >
              {tab.title}
            </button>
          ))
        }
      </div>

      <div
        class="glass-soft card-hover rounded-3xl p-8 border border-white/10 reveal"
        data-scope-card
      >
        <div class="flex items-center gap-3 mb-4">
          <span
            class="w-9 h-9 rounded-full bg-white/10 border border-white/10 flex items-center justify-center text-sky-200"
          >
            <svg
              class="w-4 h-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.6"
                d="M12 5v14m0 0l5-5m-5 5l-5-5"></path>
            </svg>
          </span>
          <div>
            <p
              class="text-xs uppercase tracking-[0.2em] text-slate-500"
              data-scope-subtitle
            >
              What the literature shows
            </p>
            <h3 class="text-xl font-semibold text-white" data-scope-title>
              Literature Survey
            </h3>
          </div>
        </div>
        <p class="text-slate-400 leading-relaxed" data-scope-body>
          Existing Kubernetes systems use service meshes and monitoring tools to
          manage microservices, but they rely heavily on sidecar proxies and
          high-level metrics like CPU and memory. While tools like eBPF enable
          low-level observability, their integration into orchestration for
          real-time decision-making is still limited.
        </p>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ scopeTabs }}>
  const tabsRoot = document.querySelector("[data-scope-tabs]");
  const titleEl = document.querySelector("[data-scope-title]");
  const subtitleEl = document.querySelector("[data-scope-subtitle]");
  const bodyEl = document.querySelector("[data-scope-body]");

  if (tabsRoot && titleEl && subtitleEl && bodyEl) {
    const tabs = Array.from(tabsRoot.querySelectorAll("button[data-tab]"));
    const data = scopeTabs;

    const setActive = (id) => {
      if (!id) return;
      const selected = data.find((item) => item.id === id);
      if (!selected) return;
      titleEl.textContent = selected.title;
      subtitleEl.textContent = selected.subtitle;
      bodyEl.textContent = selected.body;

      tabs.forEach((btn) => {
        const isActive = btn.dataset.tab === id;
        btn.setAttribute("aria-selected", isActive ? "true" : "false");
        btn.classList.toggle("bg-white/10", isActive);
        btn.classList.toggle("text-white", isActive);
        btn.classList.toggle("border-white/20", isActive);
        btn.classList.toggle("bg-white/5", !isActive);
        btn.classList.toggle("text-slate-300", !isActive);
        btn.classList.toggle("border-white/10", !isActive);
      });
    };

    tabs.forEach((btn) => {
      btn.addEventListener("click", () => setActive(btn.dataset.tab));
    });
  }
</script>
