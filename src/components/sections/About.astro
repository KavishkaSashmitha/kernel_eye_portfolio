---
const scopeTabs = [
  {
    id: "overview",
    title: "Overview",
    subtitle: "Project summary",
    body:
      "KernelEye investigates how kernel-level telemetry collected through eBPF can be used to support lower-overhead and more adaptive Kubernetes orchestration compared to traditional sidecar-heavy approaches."
  },
  {
    id: "problem",
    title: "Research Problem",
    subtitle: "Why this matters",
    body:
      "Existing service mesh approaches improve traffic control and observability, but often introduce extra resource usage, startup delay, and management complexity. KernelEye explores a lightweight alternative using kernel-level telemetry to support more efficient orchestration."
  },
  {
    id: "runtime",
    title: "Runtime Awareness",
    subtitle: "Adaptive orchestration",
    body:
      "The project is designed around runtime awareness, enabling orchestration logic to respond to real system and network conditions rather than relying only on conventional metrics."
  },
  {
    id: "objectives",
    title: "Objectives",
    subtitle: "Research direction",
    body:
      "Develop a sidecar-less orchestration approach that combines telemetry collection, intelligent routing, runtime-aware scaling, and distributed coordination within Kubernetes."
  },
  {
    id: "technology",
    title: "Technologies",
    subtitle: "Core stack",
    body:
      "eBPF for kernel-level telemetry, Kubernetes (with DaemonSet, Scale and Binding APIs) for orchestration, Go for the node-level daemon and its Service Provider Interface, and WebSocket-based peer-to-peer messaging for decentralized, runtime-aware decision making"
  }
];
---

<section id="scope" class="py-16 relative">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-8 reveal">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold font-heading tracking-tight text-white">
          Project Scope
        </h2>
        <p class="text-slate-400 mt-4 max-w-2xl">
          KernelEye investigates how kernel-level telemetry collected through eBPF can be used to support lower-overhead and more adaptive Kubernetes orchestration compared to traditional sidecar-heavy approaches.
        </p>
      </div>
    </div>

    <div class="space-y-6">
      <div class="flex flex-wrap gap-3 justify-center lg:justify-start reveal" data-scope-tabs>
        {scopeTabs.map((tab, index) => (
          <button
            class={`focus-ring rounded-full px-4 py-2 text-sm font-medium border transition whitespace-nowrap ${
              index === 0
                ? "bg-white/10 text-white border-white/20"
                : "bg-white/5 text-slate-300 border-white/10 hover:border-white/20 hover:bg-white/10"
            }`}
            data-tab={tab.id}
            aria-selected={index === 0 ? "true" : "false"}
            type="button"
          >
            {tab.title}
          </button>
        ))}
      </div>

      <div class="glass-soft card-hover rounded-3xl p-8 border border-white/10 reveal" data-scope-card>
        <div class="flex items-center gap-3 mb-4">
          <span class="w-9 h-9 rounded-full bg-white/10 border border-white/10 flex items-center justify-center text-sky-200">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M12 5v14m0 0l5-5m-5 5l-5-5" />
            </svg>
          </span>
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500" data-scope-subtitle>Project summary</p>
            <h3 class="text-xl font-semibold text-white" data-scope-title>Overview</h3>
          </div>
        </div>
        <p class="text-slate-400 leading-relaxed" data-scope-body>
          KernelEye investigates how kernel-level telemetry collected through eBPF can be used to support lower-overhead and more adaptive Kubernetes orchestration compared to traditional sidecar-heavy approaches.
        </p>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ scopeTabs }}>
  const tabsRoot = document.querySelector("[data-scope-tabs]");
  const titleEl = document.querySelector("[data-scope-title]");
  const subtitleEl = document.querySelector("[data-scope-subtitle]");
  const bodyEl = document.querySelector("[data-scope-body]");

  if (tabsRoot && titleEl && subtitleEl && bodyEl) {
    const tabs = Array.from(
      tabsRoot.querySelectorAll("button[data-tab]"),
    );
    const data = scopeTabs;

    const setActive = (id) => {
      if (!id) return;
      const selected = data.find((item) => item.id === id);
      if (!selected) return;
      titleEl.textContent = selected.title;
      subtitleEl.textContent = selected.subtitle;
      bodyEl.textContent = selected.body;

      tabs.forEach((btn) => {
        const isActive = btn.dataset.tab === id;
        btn.setAttribute("aria-selected", isActive ? "true" : "false");
        btn.classList.toggle("bg-white/10", isActive);
        btn.classList.toggle("text-white", isActive);
        btn.classList.toggle("border-white/20", isActive);
        btn.classList.toggle("bg-white/5", !isActive);
        btn.classList.toggle("text-slate-300", !isActive);
        btn.classList.toggle("border-white/10", !isActive);
      });
    };

    tabs.forEach((btn) => {
      btn.addEventListener("click", () => setActive(btn.dataset.tab));
    });
  }
</script>
