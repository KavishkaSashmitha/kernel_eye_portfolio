---

<section id="downloads" class="py-16 relative">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8 reveal">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold font-heading tracking-tight text-white">
          Research Resources
        </h2>
        <p class="mt-2 text-slate-300 text-sm">
          Access the latest project documents and deliverables.
        </p>
      </div>
      <div class="glass-soft rounded-xl px-4 py-2.5 border border-white/10 text-sm shrink-0">
        <span class="text-slate-400">Project ID: </span>
        <span class="text-white font-semibold">25-26J-434</span>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {documents.map((item) => (
        <div class="glass-soft card-hover rounded-2xl p-5 border border-white/10 flex flex-col justify-between reveal">
          <div>
            <!-- Icon -->
            <div class="w-10 h-10 rounded-xl bg-sky-500/15 border border-sky-400/25 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="text-base font-semibold text-white mb-1.5 tracking-tight">{item.title}</h3>
            <p class="text-xs text-slate-300 leading-relaxed">{item.description}</p>
          </div>

          <a
            href={item.url}
            target="_blank"
            rel="noreferrer"
            class="focus-ring mt-5 inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all bg-sky-600 hover:bg-sky-500 text-white"
          >
            View Resource
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
      ))}
    </div>

  </div>
</section>
