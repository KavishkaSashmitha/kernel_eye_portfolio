    title: "TAF",
    description: "Topic assessment form covering project background and initial scope definition.",
    url: "https://drive.google.com/file/d/1W4bP6fZUgI4g0wzNWet1l_kBDSgRy1Nk/view?usp=sharing?download=true",
  },
  {
    title: "Project Presentation 1",
    description: "Proposal document covering project background, motivation, and research scope.",
    url: "https://drive.google.com/file/d/1R53zpnufp4wdBFS-moaW9kCB2lnq3jNY/view?usp=sharing?download=true",
  },
  {
    title: "Project Presentation 2",
    description: "Research writing based on the KernelEye architecture and findings.",
    url: "https://drive.google.com/file/d/1lFXmO2KFVdIa5iSoN6Ri3P4mR8I0yFB5/view?usp=sharing?download=true",
  },
  {
    title: "Research Paper",
    description: "Comprehensive final report of the research and implementation outcomes.",
    url: "#",
  },
  {
    title: "Final Report",
