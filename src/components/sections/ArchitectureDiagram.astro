---
import { extname } from "node:path";
import { readdirSync } from "node:fs";

const architectureDir = new URL(
  "../../../public/images/architecture",
  import.meta.url,
);
const supportedImageExtensions = new Set([
  ".png",
  ".jpg",
  ".jpeg",
  ".webp",
  ".svg",
  ".gif",
]);

const toTitle = (fileName: string) =>
  fileName
    .replace(/\.[^/.]+$/, "")
    .replace(/[-_]+/g, " ")
    .replace(/\b\w/g, (char) => char.toUpperCase());

const toCaption = (fileName: string) => {
  const lower = fileName.toLowerCase();
  if (lower.includes("daemonset") || lower.includes("daemon")) return "DaemonSet View";
  if (lower.includes("logical")) return "Logical View";
  return "System View";
};

const allDiagrams = readdirSync(architectureDir)
  .filter((fileName) =>
    supportedImageExtensions.has(extname(fileName).toLowerCase()),
  )
  .map((fileName) => ({
    src: `/images/architecture/${encodeURIComponent(fileName)}`,
    title: toTitle(fileName),
    caption: toCaption(fileName),
    fileName,
  }));

// Put DaemonSet view first
const diagrams = [
  ...allDiagrams.filter((d) => d.fileName.toLowerCase().includes("daemon")),
  ...allDiagrams.filter((d) => !d.fileName.toLowerCase().includes("daemon")),
];
---

<section id="architecture" class="py-12 relative">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-8 reveal"
    >
      <div>
        <div
          class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-sky-200 text-xs tracking-wide uppercase mb-4"
        >
          Architecture Diagram
        </div>
        <h2
          class="text-3xl md:text-4xl font-bold font-heading tracking-tight text-white"
        >
          System Architecture
        </h2>
      </div>
    </div>

    <div class="glass-soft rounded-3xl border border-white/10 overflow-hidden reveal">
      {
        diagrams.length > 0 ? (
          <div class="flex flex-col lg:flex-row">
            <!-- Left: description text -->
            <div class="lg:w-[38%] shrink-0 flex flex-col gap-6 p-6 sm:p-8 lg:border-r border-b lg:border-b-0 border-white/10">
              <div class="space-y-3">
                <div class="flex items-center gap-2">
                  <div class="w-7 h-7 rounded-md bg-sky-500/20 border border-sky-500/30 flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" />
                    </svg>
                  </div>
                  <span class="text-sky-300 text-xs font-semibold uppercase tracking-widest">
                    Kernel-Level Telemetry
                  </span>
                </div>
                <p class="text-slate-400 text-sm leading-relaxed">
                  Architecture integrates kernel-level telemetry collection using{" "}
                  <span class="text-sky-300 font-medium">eBPF</span>, enabling
                  low-overhead, high-fidelity visibility into system and network
                  operations. This eliminates the need for intrusive
                  application-level instrumentation and reduces resource
                  consumption compared to conventional observability tools.
                </p>
              </div>

              <div class="w-full h-px bg-white/8" />

              <div class="space-y-3">
                <div class="flex items-center gap-2">
                  <div class="w-7 h-7 rounded-md bg-violet-500/20 border border-violet-500/30 flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                  </div>
                  <span class="text-violet-300 text-xs font-semibold uppercase tracking-widest">
                    Intelligent Orchestration
                  </span>
                </div>
                <p class="text-slate-400 text-sm leading-relaxed">
                  The collected telemetry is processed by an{" "}
                  <span class="text-violet-300 font-medium">
                    intelligent decision engine
                  </span>
                  , which analyzes runtime conditions such as latency, packet
                  loss, and resource utilization. Based on these insights, the
                  system dynamically adjusts traffic routing and workload
                  placement through an intent-aware orchestration layer,
                  ensuring optimal service performance and efficient resource
                  usage.
                </p>
              </div>

              <!-- Dot indicators -->
              <div class="mt-auto flex items-center gap-2 pt-2">
                {diagrams.map((_, i) => (
                  <button
                    class="arch-dot w-2 h-2 rounded-full transition-all duration-300 bg-white/20 hover:bg-white/40"
                    data-index={i}
                    aria-label={`Go to slide ${i + 1}`}
                  />
                ))}
              </div>
            </div>

            <!-- Right: slideshow -->
            <div class="flex-1 p-4 sm:p-5 flex flex-col gap-3">
              <!-- Slide container -->
              <div class="relative flex-1 min-h-70 overflow-hidden rounded-xl">
                <div
                  id="arch-track"
                  class="flex h-full transition-transform duration-500 ease-in-out"
                  style="width: 100%;"
                >
                  {diagrams.map((diagram, i) => (
                    <figure
                      class="arch-slide shrink-0 w-full h-full rounded-xl overflow-hidden border border-white/10 flex flex-col"
                      data-index={i}
                    >
                      <div class="flex-1 overflow-hidden">
                        <img
                          src={diagram.src}
                          alt={`Architecture diagram: ${diagram.title}`}
                          loading="lazy"
                          class="w-full h-full object-contain bg-white/5 transition-transform duration-300 hover:scale-[1.02]"
                        />
                      </div>
                      <figcaption class="px-3 py-2 text-xs text-slate-400 text-center border-t border-white/10 shrink-0">
                        {diagram.caption}
                      </figcaption>
                    </figure>
                  ))}
                </div>

                <!-- Prev arrow -->
                <button
                  id="arch-prev"
                  class="absolute left-2 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-black/50 border border-white/10 flex items-center justify-center text-white hover:bg-black/70 transition-all duration-200 backdrop-blur-sm z-10 opacity-50 hover:opacity-100"
                  aria-label="Previous diagram"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                  </svg>
                </button>

                <!-- Next arrow -->
                <button
                  id="arch-next"
                  class="absolute right-2 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-black/50 border border-white/10 flex items-center justify-center text-white hover:bg-black/70 transition-all duration-200 backdrop-blur-sm z-10 opacity-50 hover:opacity-100"
                  aria-label="Next diagram"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </button>
              </div>

              <!-- Slide counter -->
              <div class="text-center text-xs text-slate-500">
                <span id="arch-counter">1</span> / {diagrams.length}
              </div>
            </div>
          </div>
        ) : (
          <div class="p-6 rounded-2xl border border-dashed border-white/20 min-h-52 flex items-center justify-center text-center px-6">
            <p class="text-slate-400 text-sm max-w-xl">
              No architecture diagrams found in
              <span class="text-slate-200"> public/images/architecture </span>.
              Add image files there and refresh the page.
            </p>
          </div>
        )
      }
    </div>
  </div>
</section>

<script>
  const total = document.querySelectorAll(".arch-slide").length;
  if (total > 0) {
    let current = 0;
    const track = document.getElementById("arch-track") as HTMLElement;
    const counter = document.getElementById("arch-counter") as HTMLElement;
    const dots = document.querySelectorAll<HTMLButtonElement>(".arch-dot");

    const goTo = (index: number) => {
      current = (index + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      counter.textContent = String(current + 1);
      dots.forEach((d, i) => {
        d.classList.toggle("bg-sky-400", i === current);
        d.classList.toggle("scale-125", i === current);
        d.classList.toggle("bg-white/20", i !== current);
        d.classList.remove("hover:bg-white/40");
      });
    };

    document.getElementById("arch-next")?.addEventListener("click", () => goTo(current + 1));
    document.getElementById("arch-prev")?.addEventListener("click", () => goTo(current - 1));
    dots.forEach((dot) => {
      dot.addEventListener("click", () => goTo(Number(dot.dataset.index)));
    });

    // Init first dot active
    goTo(0);
  }
</script>
