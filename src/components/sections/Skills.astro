---
const technologies = [
  {
    name: "Kubernetes",
    accent: "sky",
    description: "Cluster orchestration and workload scheduling.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 3l7 4v10l-7 4-7-4V7l7-4zm0 4.2l3 1.7v5l-3 1.7-3-1.7v-5l3-1.7z" />`,
  },
  {
    name: "eBPF",
    accent: "emerald",
    description: "Kernel-level telemetry and observability.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 8h10a2 2 0 012 2v4a2 2 0 01-2 2H7a2 2 0 01-2-2v-4a2 2 0 012-2zm2-3v3m6-3v3M9 17v2m6-2v2M5 11h2m10 0h2" />`,
  },
  {
    name: "Golang (Go)",
    accent: "cyan",
    description: "Node-level daemon and SPI implementation.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8.5 10.5h3.8a2.5 2.5 0 010 5H9.5a2.5 2.5 0 110-5m6.2 0h2.3m-2.3 2.5h1.8" />`,
  },
  {
    name: "Docker",
    accent: "blue",
    description: "Container packaging for local and lab deployment.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 10.5h2v2H6v-2zm2 0h2v2H8v-2zm2 0h2v2h-2v-2zm2 0h2v2h-2v-2zm-8 2h12c0 4-2.8 6.5-6.5 6.5S4 16.5 4 12.5c0-.7.1-1.4.2-2z" />`,
  },
  {
    name: "WebSockets",
    accent: "violet",
    description: "Real-time coordination between components.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h4m6 0h4M9 8l4 4-4 4m6-8l-4 4 4 4" />`,
  },
  {
    name: "MongoDB",
    accent: "emerald",
    description: "Operational storage for coordination data.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 3c2.8 2.6 4.3 5.2 4.3 8.3 0 3.8-2 6.6-4.3 9.7-2.3-3.1-4.3-5.9-4.3-9.7C7.7 8.2 9.2 5.6 12 3zm0 5.2v9.1" />`,
  },
  {
    name: "SPI",
    accent: "amber",
    description: "Service integration interface for extensibility.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8 5h8v4H8V5zm0 10h8v4H8v-4zm-2-7h2m8 0h2m-12 7h2m8 0h2" />`,
  },
  {
    name: "Contabo VPS",
    accent: "slate",
    description: "Deployment environment for the prototype stack.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 12.5a4 4 0 014-4 4.6 4.6 0 018.7 1.6A3.5 3.5 0 0118 17H8.2A4.2 4.2 0 014 12.5z" />`,
  },
];

const accentStyles: Record<string, { shell: string; icon: string }> = {
  sky: {
    shell: "bg-sky-500/15 border-sky-400/20 text-sky-300",
    icon: "bg-sky-500/10 border-sky-400/20 text-sky-300",
  },
  emerald: {
    shell: "bg-emerald-500/15 border-emerald-400/20 text-emerald-300",
    icon: "bg-emerald-500/10 border-emerald-400/20 text-emerald-300",
  },
  cyan: {
    shell: "bg-cyan-500/15 border-cyan-400/20 text-cyan-300",
    icon: "bg-cyan-500/10 border-cyan-400/20 text-cyan-300",
  },
  blue: {
    shell: "bg-blue-500/15 border-blue-400/20 text-blue-300",
    icon: "bg-blue-500/10 border-blue-400/20 text-blue-300",
  },
  violet: {
    shell: "bg-violet-500/15 border-violet-400/20 text-violet-300",
    icon: "bg-violet-500/10 border-violet-400/20 text-violet-300",
  },
  amber: {
    shell: "bg-amber-500/15 border-amber-400/20 text-amber-300",
    icon: "bg-amber-500/10 border-amber-400/20 text-amber-300",
  },
  slate: {
    shell: "bg-slate-500/15 border-slate-400/20 text-slate-300",
    icon: "bg-slate-500/10 border-slate-400/20 text-slate-300",
  },
};
---

<section id="technologies" class="py-16 relative bg-zinc-900/30">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-8 reveal"
    >
      <div>
        <div
          class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-sky-200 text-xs tracking-wide uppercase mb-4"
        >
          Technologies Used
        </div>
        <h2
          class="text-3xl md:text-4xl font-bold font-heading tracking-tight text-white"
        >
          Technology Stack
        </h2>
        <p class="text-slate-400 mt-4 max-w-2xl">
          The project uses a compact stack built around Kubernetes
          orchestration, kernel telemetry, and lightweight communication layers
          to support runtime-aware decisions.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5">
      {
        technologies.map((tech) => {
          const accent = accentStyles[tech.accent];

          return (
            <div
              class={`glass-soft card-hover rounded-2xl p-5 border border-white/10 reveal ${accent.shell}`}
            >
              <div class="flex items-start gap-3">
                <div
                  class={`w-12 h-12 shrink-0 rounded-xl border flex items-center justify-center ${accent.icon}`}
                >
                  <svg
                    class="w-6 h-6"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    aria-hidden="true"
                    set:html={tech.icon}
                  />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-white leading-snug">
                    {tech.name}
                  </h3>
                  <p class="text-sm text-slate-300 leading-relaxed mt-1">
                    {tech.description}
                  </p>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
