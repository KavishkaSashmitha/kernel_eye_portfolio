---
---

<section id="achievements" class="py-16 relative bg-zinc-900/30">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 reveal">
      <h2 class="text-3xl md:text-4xl font-bold font-heading tracking-tight text-white">
        Research Achievement
      </h2>
      <p class="text-slate-400 mt-3 max-w-2xl mx-auto">
        Key recognition, research outputs, and public presentations from the KernelEye journey.
      </p>
    </div>

    <!-- Coming Soon Banner -->
    <div class="glass-soft rounded-2xl border border-white/10 p-10 reveal flex flex-col items-center justify-center text-center mb-8">
      <div class="w-14 h-14 rounded-full bg-sky-500/10 border border-sky-400/25 flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z" />
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-white mb-2">Coming Soon</h3>
      <p class="text-sm text-slate-400 max-w-md">Research achievements and recognition milestones will be published here once the work is formally presented and validated.</p>
    </div>

    <!-- Skeleton Cards -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mb-8">
      {[0, 1, 2].map(() => (
        <div class="glass-soft rounded-2xl p-5 border border-white/10 animate-pulse">
          <div class="flex items-center justify-between gap-3 mb-3">
            <div class="h-4 bg-white/10 rounded-full w-2/3"></div>
            <div class="h-4 bg-white/10 rounded-full w-16"></div>
          </div>
          <div class="space-y-2 mb-4">
            <div class="h-3 bg-white/10 rounded-full w-full"></div>
            <div class="h-3 bg-white/10 rounded-full w-5/6"></div>
            <div class="h-3 bg-white/10 rounded-full w-4/6"></div>
          </div>
          <div class="flex gap-1.5">
            <div class="h-5 bg-white/10 rounded-full w-16"></div>
            <div class="h-5 bg-white/10 rounded-full w-20"></div>
            <div class="h-5 bg-white/10 rounded-full w-14"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Skeleton Grid -->
    <div class="glass-soft rounded-2xl border border-white/10 p-5 reveal animate-pulse">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {[0, 1, 2, 3].map(() => (
          <div class="rounded-xl bg-white/5 border border-white/10 h-24"></div>
        ))}
      </div>
    </div>
  </div>
</section>
