---
const milestones = [
  {
    title: "Topic Assessment",
    num: "M1",
    date: "SEP 2025",
    status: "Done",
    tags: ["#research", "#scope"],
    description: "Established the core problem statement and validated the initial research direction.",
  },
  {
    title: "Proposal Presentation",
    num: "M2",
    date: "OCT 2025",
    status: "Done",
    tags: ["#proposal", "#planning"],
    description: "Presented the project scope, motivation, objectives, and proposed solution strategy.",
  },
  {
    title: "Progress Presentation 1",
    num: "M3",
    date: "DEC 2025",
    status: "Done",
    tags: ["#design", "#architecture"],
    description: "Reviewed the initial system design, architecture decisions, and module-level direction.",
  },
  {
    title: "Progress Presentation 2",
    num: "M4",
    date: "MAR 2026",
    status: "Done",
    tags: ["#implementation", "#validation"],
    description: "Demonstrated implementation progress with focused validation of key components.",
  },
  {
    title: "Research Paper",
    num: "M5",
    date: "MAR 2026",
    status: "Done",
    tags: ["#paper", "#publication"],
    description: "Developed the research manuscript with technical analysis and publication-ready documentation.",
  },
  {
    title: "Final Report",
    num: "M6",
    date: "MAR 2026",
    status: "In Work",
    tags: ["#report", "#evaluation"],
    description: "Compiling the complete project report, including implementation details and evaluation outcomes.",
  },
  {
    title: "Final Presentation / Viva",
    num: "M7",
    date: "APR 2026",
    status: "Planned",
    tags: ["#defense", "#demo"],
    description: "Preparing for the final defense with a comprehensive demonstration of research outcomes.",
  },
];

function chipClass(status: string) {
  if (status === "Done")    return "badge-completed";
  if (status === "In Work") return "badge-ongoing";
  return "badge-upcoming";
}
---

<section id="milestones" class="py-16 relative bg-zinc-900/30">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl md:text-4xl font-bold font-heading tracking-tight text-white">
        Project Milestones
      </h2>
      <p class="text-slate-400 mt-2 text-sm">
        Key research checkpoints and academic deliverables.
      </p>
    </div>

    <div class="relative">
      <!-- Centre spine -->
      <div class="absolute left-1/2 -translate-x-px top-0 bottom-0 w-px bg-white/10 hidden md:block"></div>
      <!-- Mobile spine -->
      <div class="absolute left-4 top-0 bottom-0 w-px bg-white/10 md:hidden"></div>

      <div class="space-y-12">
        {milestones.map((item, index) => {
          const isLeft = index % 2 === 0;
          const delay  = index * 80;
          const isDone    = item.status === "Done";
          const isInWork  = item.status === "In Work";
          return (
            <div class="relative flex items-center reveal" style={`transition-delay: ${delay}ms`}>

              <!-- ── DESKTOP ── -->

              {/* Left card (even) */}
              <div class={`hidden md:block w-5/12 ${isLeft ? "" : "invisible pointer-events-none"}`}>
                {isLeft && (
                  <div class="glass-soft rounded-2xl border border-white/10 p-6 hover:border-sky-400/30 hover:shadow-[0_0_24px_rgba(56,189,248,0.08)] hover:-translate-y-1 transition-all duration-200 cursor-default mr-10">
                    <div class="flex items-start justify-between gap-3 mb-3">
                      <span class="text-xs font-medium text-slate-400 bg-white/5 border border-white/10 rounded-full px-3 py-1">
                        {item.date}
                      </span>
                      <span class={`text-xs px-2.5 py-1 rounded-full border font-medium ${chipClass(item.status)}`}>
                        {item.status}
                      </span>
                    </div>
                    <h3 class="text-base font-semibold text-white mb-2">{item.title}</h3>
                    <p class="text-sm text-slate-400 leading-relaxed mb-4">{item.description}</p>
                    <div class="flex flex-wrap gap-1.5">
                      {item.tags.map(tag => (
                        <span class="text-xs text-slate-500 bg-white/5 rounded-full px-2 py-0.5">{tag}</span>
                      ))}
                    </div>
                  </div>
                )}
              </div>

              {/* Centre dot */}
              <div class={`
                hidden md:flex absolute left-1/2 -translate-x-1/2 z-10
                w-8 h-8 rounded-full border-2 items-center justify-center
                ${isDone
                  ? "border-emerald-500 bg-zinc-900 shadow-[0_0_12px_rgba(52,211,153,0.4)]"
                  : isInWork
                  ? "border-sky-500 bg-zinc-900 shadow-[0_0_12px_rgba(56,189,248,0.4)]"
                  : "border-white/20 bg-zinc-900"}
              `}>
                {isDone ? (
                  <div class="w-3 h-3 rounded-full bg-emerald-500"></div>
                ) : isInWork ? (
                  <div class="w-3 h-3 rounded-full bg-sky-500 animate-pulse"></div>
                ) : (
                  <div class="w-3 h-3 rounded-full bg-zinc-600"></div>
                )}
              </div>

              {/* Right card (odd) */}
              <div class={`hidden md:block w-5/12 ml-auto ${!isLeft ? "" : "invisible pointer-events-none"}`}>
                {!isLeft && (
                  <div class="glass-soft rounded-2xl border border-white/10 p-6 hover:border-sky-400/30 hover:shadow-[0_0_24px_rgba(56,189,248,0.08)] hover:-translate-y-1 transition-all duration-200 cursor-default ml-10">
                    <div class="flex items-start justify-between gap-3 mb-3">
                      <span class="text-xs font-medium text-slate-400 bg-white/5 border border-white/10 rounded-full px-3 py-1">
                        {item.date}
                      </span>
                      <span class={`text-xs px-2.5 py-1 rounded-full border font-medium ${chipClass(item.status)}`}>
                        {item.status}
                      </span>
                    </div>
                    <h3 class="text-base font-semibold text-white mb-2">{item.title}</h3>
                    <p class="text-sm text-slate-400 leading-relaxed mb-4">{item.description}</p>
                    <div class="flex flex-wrap gap-1.5">
                      {item.tags.map(tag => (
                        <span class="text-xs text-slate-500 bg-white/5 rounded-full px-2 py-0.5">{tag}</span>
                      ))}
                    </div>
                  </div>
                )}
              </div>

              <!-- ── MOBILE ── -->
              <div class="md:hidden flex gap-4 w-full pl-1">
                {/* Dot */}
                <div class={`
                  relative z-10 w-7 h-7 rounded-full border-2 flex items-center justify-center shrink-0 mt-1
                  ${isDone
                    ? "border-emerald-500 bg-zinc-900"
                    : isInWork
                    ? "border-sky-500 bg-zinc-900"
                    : "border-white/20 bg-zinc-900"}
                `}>
                  {isDone ? (
                    <div class="w-2.5 h-2.5 rounded-full bg-emerald-500"></div>
                  ) : isInWork ? (
                    <div class="w-2.5 h-2.5 rounded-full bg-sky-500 animate-pulse"></div>
                  ) : (
                    <div class="w-2.5 h-2.5 rounded-full bg-zinc-600"></div>
                  )}
                </div>
                {/* Card */}
                <div class="glass-soft rounded-2xl border border-white/10 p-4 flex-1">
                  <div class="flex items-center justify-between gap-2 mb-2">
                    <span class="text-xs text-slate-400 bg-white/5 border border-white/10 rounded-full px-2.5 py-0.5">
                      {item.date}
                    </span>
                    <span class={`text-xs px-2 py-0.5 rounded-full border font-medium ${chipClass(item.status)}`}>
                      {item.status}
                    </span>
                  </div>
                  <h3 class="text-sm font-semibold text-white mb-1.5">{item.title}</h3>
                  <p class="text-xs text-slate-400 leading-relaxed mb-3">{item.description}</p>
                  <div class="flex flex-wrap gap-1">
                    {item.tags.map(tag => (
                      <span class="text-xs text-slate-500 bg-white/5 rounded-full px-2 py-0.5">{tag}</span>
                    ))}
                  </div>
                </div>
              </div>

            </div>
          );
        })}
      </div>
    </div>

  </div>
</section>
