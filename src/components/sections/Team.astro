---
const teamMembers = [
  {
    name: "Gunawardne D.D.I.",
    role: "Telemetry Component",
    reg: "IT22312426",
    summary:
      "Responsible for the telemetry-focused implementation and kernel-level metric collection layer.",
    initials: "GD",
    image: "/images/team",
  },
  {
    name: "Aponso G.I.A.",
    role: "Autoscaling & Scheduling Component",
    reg: "IT22603586",
    summary:
      "Responsible for runtime-aware autoscaling and intelligent scheduling logic.",
    initials: "AG",
    image: "/images/team/Ishini.jpg",
  },
  {
    name: "Samarasinghe P.P.",
    role: "Traffic Routing Component",
    reg: "IT22036384",
    summary:
      "Responsible for adaptive service traffic routing based on live telemetry conditions.",
    initials: "SP",
    image: "/images/team/Panchali.jpeg",
  },
  {
    name: "Sashmitha G.C.K.",
    role: "Distributed Coordination Component",
    reg: "IT22109262",
    summary:
      "Responsible for distributed coordination and inter-node telemetry communication.",
    image: "/images/team/Kavishka.jpg",
    initials: "SG",
  },
];

const advisors = [
  {
    name: "Dr. Dharshana Kasthurirathna",
    role: "Supervisor",
    summary: "Academic supervision and research guidance.",
    initials: "DK",
    image: "/images/team/Dharshana.jpeg",
  },
  {
    name: "Mr. Vishan Jayasinghearachchi",
    role: "Co-Supervisor",
    summary: "Technical supervision and systems direction.",
    initials: "VJ",
    image: "/images/team/Vishan.jpeg",
  },
  {
    name: "Mr. Susith Rupasinghe",
    role: "External Co-Supervisor",
    summary: "Industry supervision and implementation feedback.",
    initials: "SR",
    image: "/images/team/Susith.jpeg",
  },
];
---

<section id="team" class="py-16 relative bg-zinc-900/30">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 reveal">
      <h2 class="text-3xl md:text-4xl font-bold font-heading tracking-tight text-white">
        The Team
      </h2>
      <p class="text-slate-400 mt-4 max-w-2xl mx-auto">
        A compact research team focused on kernel telemetry, orchestration
        logic, and distributed coordination.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
      {
        teamMembers.map((member) => (
          <div class="glass-soft card-hover rounded-2xl p-5 border border-white/10 reveal">
            <div class="aspect-[4/3] w-full rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-white font-semibold text-2xl overflow-hidden">
              {member.image ? (
                <img
                  src={member.image}
                  alt={`${member.name} profile photo`}
                  loading="lazy"
                  class="w-full h-full object-cover object-center"
                />
              ) : (
                member.initials
              )}
            </div>
            <h3 class="text-lg font-semibold text-white mt-4">{member.name}</h3>
            <p class="text-xs text-slate-400 mt-1">{member.reg}</p>
            <p class="text-sm text-sky-200 mt-2">{member.role}</p>
            <p class="text-sm text-slate-400 mt-3">{member.summary}</p>
            <div class="mt-4 flex gap-3">
              <button class="focus-ring p-2 rounded-full bg-white/5 border border-white/10 text-slate-300 hover:text-white hover:bg-white/10 transition">
                <span class="sr-only">LinkedIn</span>
                <svg
                  class="w-4 h-4"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              </button>
              <button class="focus-ring p-2 rounded-full bg-white/5 border border-white/10 text-slate-300 hover:text-white hover:bg-white/10 transition">
                <span class="sr-only">GitHub</span>
                <svg
                  class="w-4 h-4"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                </svg>
              </button>
            </div>
          </div>
        ))
      }
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        advisors.map((advisor) => (
          <div class="glass-soft card-hover rounded-2xl p-5 border border-white/10 reveal">
            <div class="aspect-[4/3] w-full rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-white font-semibold text-2xl overflow-hidden ring-2 ring-sky-400/20 shadow-[0_10px_28px_rgba(0,0,0,0.35)]">
              {advisor.image ? (
                <img
                  src={advisor.image}
                  alt={`${advisor.name} profile photo`}
                  loading="lazy"
                  class="w-full h-full object-cover object-center"
                />
              ) : (
                advisor.initials
              )}
            </div>
            <h3 class="text-lg font-semibold text-white mt-4">
              {advisor.name}
            </h3>
            <p class="text-sm text-sky-200">{advisor.role}</p>
            <p class="text-sm text-slate-400 mt-3">{advisor.summary}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
