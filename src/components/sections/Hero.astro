---
---

<section id="home" class="relative min-h-[80vh] flex items-center pt-20 overflow-hidden">
  <div class="absolute inset-0 bg-grid opacity-20 pointer-events-none"></div>
  <div class="absolute -top-20 right-10 w-80 h-80 bg-sky-500/25 rounded-full blur-[110px] pointer-events-none"></div>
  <div class="absolute bottom-0 -left-20 w-96 h-96 bg-blue-500/20 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="flex flex-col lg:flex-row items-start lg:items-center gap-8 lg:gap-12">
      <div class="flex-1 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-sky-200 text-xs tracking-wide uppercase mb-6">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full rounded-full bg-sky-400/70"></span>
          </span>
          Final Year Research Project
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold font-heading tracking-tight mb-5 text-white leading-tight">
          KernelEye <br class="hidden sm:block" />
        </h1>

        <h2 class="text-lg md:text-2xl text-slate-300 font-medium mb-6 max-w-2xl mx-auto lg:mx-0">
          Architectural Optimization of Kubernetes Using Intelligent Telemetry via eBPF
        </h2>

        <p class="text-slate-400 text-base md:text-lg mb-8 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
          KernelEye is a sidecar-less Kubernetes research project that uses eBPF-based kernel telemetry to improve observability, traffic routing, and runtime orchestration decisions in cloud-native environments.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-3 sm:gap-4">
          <a href="#scope" class="focus-ring w-full sm:w-auto px-8 py-3.5 rounded-full bg-sky-600 hover:bg-sky-700 text-white font-medium transition-all transform hover:-translate-y-1 hover:shadow-[0_0_24px_rgba(56,189,248,0.45)] text-center">
            View Research
          </a>
          <a href="#contributions" class="focus-ring w-full sm:w-auto px-8 py-3.5 rounded-full bg-transparent border border-white/20 hover:border-white/40 hover:bg-white/5 text-white font-medium transition-all text-center">
            Explore Project
          </a>
        </div>
      </div>

      <div class="flex-1 w-full max-w-xl lg:max-w-none relative mt-10 lg:mt-0">
        <div class="relative w-full max-w-md sm:max-w-lg mx-auto">
          <div class="absolute -inset-6 bg-gradient-to-br from-sky-500/20 to-blue-500/10 rounded-[28px] blur-2xl"></div>
          <div class="glass-soft rounded-[28px] p-6 border border-white/10 shadow-2xl relative overflow-hidden">
            <div class="absolute -top-16 -right-12 w-52 h-52 bg-sky-500/20 rounded-full blur-[80px]"></div>
            <div class="absolute bottom-0 left-0 w-40 h-40 bg-blue-500/20 rounded-full blur-[80px]"></div>

            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-2 text-sm text-slate-300">
                <span class="inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
                Telemetry Dashboard
              </div>
              <span class="text-xs text-slate-500">KernelEye Lab</span>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="card-hover rounded-2xl bg-white/5 border border-white/10 p-4">
                <p class="text-xs text-slate-400">Latency (p95)</p>
                <p class="text-2xl font-semibold text-white mt-2">43ms</p>
                <p class="text-xs text-emerald-300 mt-2">-18% vs baseline</p>
              </div>
              <div class="card-hover rounded-2xl bg-white/5 border border-white/10 p-4">
                <p class="text-xs text-slate-400">Routing Confidence</p>
                <p class="text-2xl font-semibold text-white mt-2">0.92</p>
                <p class="text-xs text-sky-300 mt-2">Adaptive</p>
              </div>
              <div class="card-hover rounded-2xl bg-white/5 border border-white/10 p-4 sm:col-span-2">
                <p class="text-xs text-slate-400">Active Signals</p>
                <div class="flex flex-wrap gap-2 mt-3">
                  <span class="text-xs px-2.5 py-1 rounded-full bg-sky-500/20 text-sky-200 border border-sky-400/30">eBPF flows</span>
                  <span class="text-xs px-2.5 py-1 rounded-full bg-blue-500/20 text-blue-200 border border-blue-400/30">Service SLA</span>
                  <span class="text-xs px-2.5 py-1 rounded-full bg-emerald-500/20 text-emerald-200 border border-emerald-400/30">Runtime health</span>
                  <span class="text-xs px-2.5 py-1 rounded-full bg-white/10 text-slate-200 border border-white/10">Policy triggers</span>
                </div>
              </div>
            </div>

            <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-3 text-xs text-slate-400">
              <div class="card-hover rounded-xl bg-white/5 border border-white/10 p-3 text-center">
                <p class="text-slate-300 font-medium">Cluster A</p>
                <p class="mt-2 text-emerald-300">Stable</p>
              </div>
              <div class="card-hover rounded-xl bg-white/5 border border-white/10 p-3 text-center">
                <p class="text-slate-300 font-medium">Cluster B</p>
                <p class="mt-2 text-amber-300">Degraded</p>
              </div>
              <div class="card-hover rounded-xl bg-white/5 border border-white/10 p-3 text-center">
                <p class="text-slate-300 font-medium">Cluster C</p>
                <p class="mt-2 text-sky-300">Optimizing</p>
              </div>
            </div>
          </div>

          <div class="absolute -right-6 top-10 glass-soft px-4 py-3 rounded-2xl border border-white/10 shadow-xl">
            <p class="text-xs text-slate-400">Telemetry</p>
            <p class="text-sm font-semibold text-white">1.2M signals/min</p>
          </div>

          <div class="absolute -left-6 bottom-10 glass-soft px-4 py-3 rounded-2xl border border-white/10 shadow-xl">
            <p class="text-xs text-slate-400">Policy Engine</p>
            <p class="text-sm font-semibold text-white">Adaptive routing</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
