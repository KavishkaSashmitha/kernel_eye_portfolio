---
interface Props {
  name: string;
  icon?: string;
}

const { name, icon } = Astro.props;
---

<div class="group relative flex items-center gap-3 bg-zinc-900 border border-white/5 hover:border-sky-500/50 rounded-xl px-4 py-3 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-sky-500/10">
  <div class="absolute inset-0 bg-gradient-to-r from-sky-600/0 via-sky-600/0 to-sky-600/0 group-hover:from-sky-600/5 group-hover:via-sky-600/10 group-hover:to-cyan-600/5 rounded-xl transition-all duration-500"></div>
  
  {icon && (
    <div class="w-8 h-8 flex items-center justify-center rounded-lg bg-white/5 text-sky-400 group-hover:scale-110 transition-transform duration-300" set:html={icon} />
  )}
  {!icon && (
    <div class="w-2 h-2 rounded-full bg-sky-500 group-hover:scale-150 transition-transform duration-300"></div>
  )}
  
  <span class="font-medium text-slate-300 group-hover:text-white transition-colors relative z-10">{name}</span>
</div>
