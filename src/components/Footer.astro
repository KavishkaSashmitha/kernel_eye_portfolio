---
const currentYear = new Date().getFullYear();

const socialLinks = [
  { name: 'GitHub',   url: 'https://github.com',   icon: 'M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z' },
  { name: 'LinkedIn', url: 'https://linkedin.com', icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
  { name: 'X',        url: 'https://x.com',        icon: 'M18.244 2H21l-6.75 7.71L22.5 22h-6.84l-5.35-6.66L4.1 22H1.35l7.27-8.32L1.5 2h7.01l4.84 6.04L18.244 2zm-1.2 18h1.9L8.66 4h-1.9l10.284 16z' }
];

const navLinks = [
  { label: 'Home',       href: '#home' },
  { label: 'Scope',      href: '#scope' },
  { label: 'Milestones', href: '#milestones' },
  { label: 'Downloads',  href: '#downloads' },
  { label: 'Team',       href: '#team' },
  { label: 'Contact',    href: '#contact' },
];
---

<footer class="border-t border-white/10 bg-zinc-950 mt-8">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Top row -->
    <div class="flex flex-col md:flex-row justify-between gap-8">

      <!-- Brand -->
      <div class="max-w-xs">
        <a href="#home" class="text-lg font-bold font-heading text-white hover:text-sky-300 transition-colors">
          KernelEye
        </a>
        <p class="text-slate-300 text-sm mt-1 font-medium">Research Project Showcase</p>
        <p class="text-slate-400 text-xs mt-2 leading-relaxed">
          Final-year research project on runtime-aware Kubernetes orchestration using eBPF-based intelligent telemetry.
        </p>
        <div class="flex gap-2 mt-4 flex-wrap">
          {['Kubernetes', 'eBPF', 'Cloud-Native'].map(tag => (
            <span class="text-xs px-2 py-0.5 rounded-full bg-white/5 border border-white/10 text-slate-400">{tag}</span>
          ))}
        </div>
      </div>

      <!-- Nav links -->
      <div>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-3">Navigation</p>
        <ul class="grid grid-cols-2 gap-x-8 gap-y-2">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-slate-300 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social -->
      <div>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-3">Connect</p>
        <div class="flex gap-3">
          {socialLinks.map(social => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 hover:text-white hover:bg-white/10 hover:border-white/20 transition-all"
              aria-label={social.name}
            >
              <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24">
                <path d={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/5 mt-8 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-slate-500">
      <p>&copy; {currentYear} KernelEye Research Project. .</p>
      <p class="text-slate-600">Project ID: <span class="text-slate-400 font-medium">25-26J-434</span></p>
    </div>

  </div>
</footer>
